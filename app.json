{
  "expo": {
    "name": "onspace-app",
    "slug": "onspace-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "onspaceapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "16.4",
      "bundleIdentifier": "com.clipdag.onspaceapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.clipdag.onspaceapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "./plugins/withDeepARAndroidFix",
      "./plugins/withDeepARiOS",
      [
        "expo-camera",
        {
          "cameraPermission": "ClipDAG necesita la cámara para filtros AR en tiempo real",
          "microphonePermission": "ClipDAG necesita el micrófono para grabar videos"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "extraProguardRules": "-keepclassmembers class ai.deepar.ar.DeepAR { *; }\n-keepclassmembers class ai.deepar.ar.core.videotexture.VideoTextureAndroidJava { *; }\n-keep class ai.deepar.ar.core.videotexture.VideoTextureAndroidJava"
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      ["@stripe/stripe-react-native", {}],
      "expo-asset",
      "expo-audio",
      "expo-font",
      "expo-localization",
      "expo-mail-composer",
      "expo-secure-store",
      "expo-sqlite",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#ffffff",
          "mode": "production"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ClipDAG necesita tu ubicación para mostrarte contenido cercano"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ClipDAG necesita acceso a tu galería para subir videos y fotos",
          "savePhotosPermission": "ClipDAG necesita acceso para guardar videos en tu galería",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ClipDAG usa Face ID para proteger tu cuenta"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "ClipDAG necesita acceso a tus contactos para que puedas conectar con amigos"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "ClipDAG necesita acceso al calendario para programar tus publicaciones"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51815f47-274c-427a-b496-10e1bed06d23"
      }
    }
  }
}
