{
  "expo": {
    "name": "onspace-app",
    "slug": "onspace-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "onspaceapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "16.4"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.clipdag.onspaceapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "./plugins/withDeepARAndroidFix",
      [
        "expo-camera",
        {
          "cameraPermission": "ClipDAG necesita la cámara para filtros AR en tiempo real",
          "microphonePermission": "ClipDAG necesita el micrófono para grabar videos"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "extraProguardRules": "-keepclassmembers class ai.deepar.ar.DeepAR { *; }\n-keepclassmembers class ai.deepar.ar.core.videotexture.VideoTextureAndroidJava { *; }\n-keep class ai.deepar.ar.core.videotexture.VideoTextureAndroidJava"
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51815f47-274c-427a-b496-10e1bed06d23"
      }
    }
  }
}
