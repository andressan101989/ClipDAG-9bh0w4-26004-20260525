# ─────────────────────────────────────────────────────────────────────────────
# ClipDAG — Environment Variables Template
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── OnSpace Cloud / Supabase ──────────────────────────────────────────────────
# Found in your OnSpace Cloud or Supabase project dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Obtain a project ID at https://cloud.walletconnect.com
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── DeepAR (AR effects / face filters) ───────────────────────────────────────
# Obtain license keys at https://www.deepar.ai
# iOS key goes into Info.plist via plugins/withDeepARiOS.js at EAS build time.
# Android key goes into strings.xml via plugins/withDeepARAndroidFix.js.
EXPO_PUBLIC_DEEPAR_LICENSE_IOS=
EXPO_PUBLIC_DEEPAR_LICENSE_ANDROID=

# ── Deezer music integration (optional) ──────────────────────────────────────
EXPO_PUBLIC_DEEZER_APP_ID=

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT add real credentials here.
# This file is committed to the repo as a safe reference template only.
# ─────────────────────────────────────────────────────────────────────────────
